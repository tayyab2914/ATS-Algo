# ATS-ALGO — environment template. Copy to `.env` and fill in.

# Database (Supabase Postgres). Use the Session Pooler URL for both.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# JWT session signing secret (generate: openssl rand -hex 48)
JWT_SECRET="replace-with-a-long-random-secret"

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PIN="0000"

# SMTP (email verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASS="app-password"
SMTP_FROM="ATS-ALGO <you@example.com>"

# App
APP_URL="https://ats-algo.vercel.app"

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
