# ATS-ALGO — environment template. Copy to `.env` and fill in.

# Database (Supabase Postgres).
# DATABASE_URL = Transaction pooler (port 6543) — runtime queries; multiplexes
#   clients so serverless deploys don't exhaust the connection limit.
# DIRECT_URL   = Session pooler (port 5432) — migrations only.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# JWT session signing secret (generate: openssl rand -hex 48)
JWT_SECRET="replace-with-a-long-random-secret"

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PIN="0000"
# Superadmin: signs in through the same admin code flow, and is the only account
# allowed to delete admins and members from Admin Management.
SUPERADMIN_EMAIL="superadmin@example.com"

# SMTP (email verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASS="app-password"
SMTP_FROM="ATS-ALGO <you@example.com>"

# App
APP_URL="https://ats-algo.vercel.app"

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Stripe subscription billing
# Secret API key (test mode starts with sk_test_).
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret for /api/stripe/webhook (from `stripe listen` or the Dashboard).
STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring price IDs: $49/month and $559/year.
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_YEARLY="price_..."
