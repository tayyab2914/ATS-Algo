// Prisma schema — Adrian Trading System
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user. Passwords are stored only as bcrypt hashes.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  verificationTokens VerificationToken[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

/// One-time, expiring code emailed to the admin address for passwordless admin
/// sign-in. The code is stored hashed; only one is active at a time.
model AdminLoginCode {
  id        String   @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("admin_login_codes")
}

/// Single-use, expiring token emailed to a user to confirm their address.
model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("verification_tokens")
}
