// Prisma schema — ATS-ALGO
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user. Passwords are stored only as bcrypt hashes.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Account standing, controlled from the Admin Management screen. SUSPENDED is
  // a reversible hold; BANNED is a hard block. Both deny sign-in and invalidate
  // any live session on the next request.
  status AccountStatus @default(ACTIVE)

  // Any session JWT issued before this instant is rejected, even if otherwise
  // valid and unexpired. Bumping it to `now()` is how an admin force-logs-out a
  // user without a server-side session store (the JWTs are stateless). Also
  // bumped on sign-out, so it doubles as the "signed out at" marker.
  sessionsValidFrom DateTime?

  // When the user last started a session. Paired with `sessionsValidFrom` this
  // is enough to tell, without a session store, whether a live session exists:
  // a login newer than the last revocation and inside the 7-day token window.
  lastLoginAt DateTime?

  // Account settings
  avatarUrl            String?
  tradingViewConnected Boolean @default(false)
  walletConnected      Boolean @default(false)
  walletAddress        String?

  // When true, login requires a one-time code emailed to this address.
  twoFactorEnabled Boolean @default(false)

  // Set the first time the user accepts the mandatory Rules & Policy. While
  // null, an authenticated user is held on the /policy acceptance gate and
  // cannot reach any in-app route.
  policyAcceptedAt DateTime?

  // Stripe customer id, created lazily the first time the user starts checkout
  // or opens the billing portal. One customer per user.
  stripeCustomerId String? @unique

  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  exchangeConnections ExchangeConnection[]
  twoFactorCodes      TwoFactorCode[]
  subscription        Subscription?

  @@map("users")
}

/// A user's Stripe subscription, mirrored from Stripe via webhooks. Stripe is
/// the source of truth; this row is a read-optimized cache the app gates on so
/// it never has to call Stripe to check entitlement. One subscription per user.
model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Null for an admin-granted comp subscription that never touched Stripe.
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 BillingPlan
  status               SubscriptionStatus
  /// End of the current paid period — also the renewal date, or the date access
  /// ends when `cancelAtPeriodEnd` is set. Null on a perpetual comp grant.
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  /// True when an admin granted this access for free (no Stripe charge). Stripe
  /// webhooks overwrite the row by user, so a later real purchase supersedes it.
  isComp               Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

/// Billing cadence, derived from the Stripe price the customer subscribed to.
enum BillingPlan {
  MONTHLY
  YEARLY
}

/// Mirror of Stripe's subscription `status` values.
enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

/// A user's connection to an exchange's API (key stored masked, never raw).
model ExchangeConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange     String
  permissions  String   @default("Read & Trade")
  apiKeyMasked String?
  createdAt    DateTime @default(now())

  @@unique([userId, exchange])
  @@map("exchange_connections")
}

enum Role {
  USER
  ADMIN
}

/// A user's account standing, managed from the Admin Management screen.
enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum UploadStatus {
  SUCCESS
  FAILED
}

/// A metrics file uploaded via the Admin Staging Dashboard.
model MetricUpload {
  id        String       @id @default(cuid())
  filename  String
  version   String
  status    UploadStatus @default(SUCCESS)
  createdAt DateTime     @default(now())

  @@map("metric_uploads")
}

/// One-time, expiring code emailed to an admin address for passwordless admin
/// sign-in. Scoped to the address it was sent to so each admin's code is
/// independent. Stored hashed; only the latest code per address is valid.
model AdminLoginCode {
  id String @id @default(cuid())
  /// The admin address this code was issued to (lowercased).
  email     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("admin_login_codes")
}

/// Single-use, expiring token emailed to a user to confirm their address.
model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("verification_tokens")
}

/// Single-use, expiring password-reset token. Stored as a SHA-256 hash; the
/// raw token only ever lives in the emailed reset link.
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

/// One-time, expiring code emailed to a 2FA-enabled user during login. The code
/// is stored hashed; only the latest code per user is valid.
model TwoFactorCode {
  id        String   @id @default(cuid())
  codeHash  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("two_factor_codes")
}
