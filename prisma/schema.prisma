// Prisma schema — Adrian Trading System
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user. Passwords are stored only as bcrypt hashes.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Account settings
  avatarUrl            String?
  tradingViewConnected Boolean @default(false)
  walletConnected      Boolean @default(false)
  walletAddress        String?

  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  exchangeConnections ExchangeConnection[]

  @@map("users")
}

/// A user's connection to an exchange's API (key stored masked, never raw).
model ExchangeConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange     String
  permissions  String   @default("Read & Trade")
  apiKeyMasked String?
  createdAt    DateTime @default(now())

  @@unique([userId, exchange])
  @@map("exchange_connections")
}

enum Role {
  USER
  ADMIN
}

/// One-time, expiring code emailed to the admin address for passwordless admin
/// sign-in. The code is stored hashed; only one is active at a time.
model AdminLoginCode {
  id        String   @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("admin_login_codes")
}

/// Single-use, expiring token emailed to a user to confirm their address.
model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("verification_tokens")
}

/// Single-use, expiring password-reset token. Stored as a SHA-256 hash; the
/// raw token only ever lives in the emailed reset link.
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}
